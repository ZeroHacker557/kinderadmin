rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Faqat autentifikatsiya qilingan foydalanuvchilar kirishi mumkin
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    // Foydalanuvchilar faqat o'z ma'lumotlarini o'qiy oladi
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }
    // Admin roli tekshiruvi
    match /children/{childId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'teacher'];
    }
    match /employees/{employeeId} {
      allow read, write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    match /transactions/{transactionId} {
      allow read, write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'accountant'];
    }
    match /attendance/{attendanceId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'teacher'];
    }
    match /groups/{groupId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
