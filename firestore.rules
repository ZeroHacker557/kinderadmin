rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Auth bo'lgan foydalanuvchiga barcha collectionlarda o'qish/yozish ruxsati.
    // Demo/dev uchun qulay. Productionda role-based qilib toraytiring.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
